{
  "name": "@codesteps/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/codegen/index.ts && react-router dev",
    "build": "tsx scripts/codegen/index.ts && react-router build",
    "typecheck": "tsx scripts/codegen/index.ts && wrangler types && react-router typegen && tsc -b",
    "test": "vitest run",
    "lint": "biome check app workers scripts",
    "codegen": "tsx scripts/codegen/index.ts",
    "validate:content": "tsx scripts/codegen/index.ts --validate-only",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@codesteps/lesson-kit": "workspace:*",
    "@mdx-js/react": "^3.1.1",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^7.18.1",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.43.1",
    "@mdx-js/rollup": "^3.1.1",
    "@react-router/dev": "^7.18.1",
    "@react-router/fs-routes": "^7.18.1",
    "@shikijs/rehype": "^4.3.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.7",
    "wrangler": "^4.107.1"
  }
}
