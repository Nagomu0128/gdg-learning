{
  "extends": "../tsconfig.base.json",
  "include": [".react-router/types/**/*", "app/**/*", "workers/**/*", "worker-configuration.d.ts"],
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    }
  }
}
